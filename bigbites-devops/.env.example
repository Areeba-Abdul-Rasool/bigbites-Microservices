# ─────────────────────────────────────────────────────────────
#  .env.example  –  copy to .env and fill in values
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Local dev (docker-compose.yml uses these) ─────────────────
MYSQL_ROOT_PASSWORD=areeb@4821

# ── Production (docker-compose.prod.yml on EC2) ───────────────
SPRING_DATASOURCE_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/BigBites?useSSL=true
DB_USER=admin
DB_PASS=REPLACE_ME

KAFKA_BROKERS=<MSK_BROKER_1>:9092,<MSK_BROKER_2>:9092

AWS_S3_BUCKET=bigbites-uploads-XXXX
AWS_REGION=ap-south-1

ECR_REGISTRY=<ACCOUNT_ID>.dkr.ecr.ap-south-1.amazonaws.com
IMAGE_TAG=latest
